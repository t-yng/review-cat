{
  "name": "main",
  "license": "MIT",
  "version": "1.3.0",
  "main": "./dist/app.js",
  "scripts": {
    "dev": "pnpm build:dev && electron --require dotenv/config ./dist/app.js",
    "build": "pnpm clean && NODE_ENV=production node esbuild.js && pnpm copy",
    "build:dev": "pnpm clean && NODE_ENV=development node esbuild.js && pnpm copy",
    "build:test": "pnpm clean && NODE_ENV=test node esbuild.js && pnpm copy",
    "package": "node build.js",
    "clean": "rimraf app & rimraf dist",
    "copy": "cpx 'assets/images/**' dist/assets/images",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint",
    "lint:all": "pnpm lint . --cache --ext .js,.ts,.tsx",
    "format": "prettier --write",
    "format:all": "pnpm format \"**/*.{js,ts,tsx,json}\"",
    "test": "jest",
    "type-check": "tsc --noEmit",
    "lint-staged": "lint-staged -p false"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json}": [
      "pnpm format"
    ],
    "*.{js,ts,tsx}": [
      "pnpm lint"
    ]
  },
  "dependencies": {
    "@apollo/client": "^3.14.0",
    "@swc/core": "^1.3.24",
    "axios": "^1.17.0",
    "cross-fetch": "^4.0.0",
    "menubar": "^9.1.0",
    "web": "workspace:*"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.5.11",
    "electron": "^36.0.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "lint-staged": "^17.0.0",
    "rimraf": "^6.0.0"
  }
}
